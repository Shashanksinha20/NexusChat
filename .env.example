# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# Clerk Authentication (https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Clerk redirect URLs (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/conversations
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/conversations

# PostgreSQL Database
# Local:   postgresql://postgres:password@localhost:5432/nexuschat
# Railway: Automatically provided as DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexuschat

# Redis (optional – required for multi-instance horizontal scaling)
# Local:   redis://localhost:6379
# Upstash: rediss://username:password@host:port
REDIS_URL=redis://localhost:6379
